# ── Auth ─────────────────────────────────────────────────────────────────────
GATEWAY_API_KEY=changeme
# GATEWAY_AUTH_DISABLED=1        # skip auth in local dev only; blocked when ENV=production
# ENV=production                 # set to block GATEWAY_AUTH_DISABLED and enforce production guards

# ── Provider API keys ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGING_FACE_HUB_TOKEN=hf_...   # only needed for gated HF models (modal bench)

# ── Backend selection ────────────────────────────────────────────────────────
# Picks the balanced-tier backend: openai | claude | vllm
AGENT_LLM=openai

# ── Model overrides (all optional — defaults shown) ──────────────────────────
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-opus-4-6
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

GATEWAY_CHEAP_MODEL=gpt-5.4-mini  # or an Ollama model name when Ollama is up
GATEWAY_PREMIUM_BACKEND=openai    # openai | claude
GATEWAY_PREMIUM_MODEL=gpt-5.5

# Force all requests to a single tier (cheap | balanced | premium)
# GATEWAY_FORCE_TIER=

# ── vLLM ─────────────────────────────────────────────────────────────────────
VLLM_BASE_URL=http://vllm:8080/v1
# VLLM_QUANTIZATION=             # e.g. awq, gptq, squeezellm
# VLLM_DTYPE=auto                # or float16, bfloat16

# ── Telemetry ────────────────────────────────────────────────────────────────
# GATEWAY_LEDGER_DB=gateway.db   # path to SQLite file; defaults to ~/.llm_inference_benchmarking/gateway_usage.db
# GATEWAY_LEDGER_DISABLED=1      # set to 1 to disable ledger entirely

# ── Modal quantization benchmark ─────────────────────────────────────────────
# QUANT_AWQ_MODEL=               # override default AWQ checkpoint on HF
# QUANT_GPTQ_MODEL=              # override default GPTQ checkpoint on HF
# MODEL_REVISION=main            # pin to exact HuggingFace commit SHA for reproducibility

# ── Load test ────────────────────────────────────────────────────────────────
# GATEWAY_BASE_URL=http://localhost:8010   # gateway URL for llm-load-test

# ── Custom per-model pricing (USD per token) ─────────────────────────────────
# GATEWAY_PRICE_IN_GPT_4O=0.0000025
# GATEWAY_PRICE_OUT_GPT_4O=0.000010

# ── Rate limiting ──────────────────────────────────────────────────────────────
# GATEWAY_RATE_LIMIT_RPM=60          # max requests per minute per IP (0 = disabled)
# GATEWAY_RATE_LIMIT_ALGO=token_bucket  # token_bucket | sliding_window

# ── SLA latency caps ───────────────────────────────────────────────────────────
# GATEWAY_SLA_P99_CHEAP_MS=2000      # p99 latency cap for cheap tier (ms), 0 = off
# GATEWAY_SLA_P99_BALANCED_MS=5000   # p99 latency cap for balanced tier
# GATEWAY_SLA_P99_PREMIUM_MS=10000   # p99 latency cap for premium tier
# GATEWAY_SLA_WINDOW=100             # number of recent requests to track

# ── Quality-aware routing ──────────────────────────────────────────────────────
# GATEWAY_QUALITY_MIN_SCORE=0.70     # min MMLU accuracy to accept a model
# GATEWAY_QUALITY_RESULTS_DIR=results/  # dir containing modal benchmark JSONs

# ── Ollama local health check ──────────────────────────────────────────────────
# GATEWAY_OLLAMA_HEALTH_TTL_S=30     # seconds to cache Ollama reachability probe

# ── Budget controls ────────────────────────────────────────────────────────────
# GATEWAY_DAILY_USD_HARD_CAP=0       # daily spend hard cap in USD; blocks requests with HTTP 402 when reached (0 = disabled)
# GATEWAY_DAILY_USD_SOFT_CAP=0       # daily spend soft cap; downgrades premium → balanced when reached (0 = disabled)
# GATEWAY_CHEAP_NO_CLOUD_FALLBACK=0  # set to 1 to fail closed when local Ollama is unreachable (no cloud fallback)

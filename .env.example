# ── Auth ─────────────────────────────────────────────────────────────────────
GATEWAY_API_KEY=changeme
# GATEWAY_AUTH_DISABLED=1        # set to 1 to skip auth in local dev

# ── Provider API keys ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGING_FACE_HUB_TOKEN=hf_...   # only needed for gated HF models (modal bench)

# ── Backend selection ────────────────────────────────────────────────────────
# Picks the balanced-tier backend: openai | claude | vllm
AGENT_LLM=openai

# ── Model overrides (all optional — defaults shown) ──────────────────────────
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-opus-4-6
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

GATEWAY_CHEAP_MODEL=gpt-5.4-mini  # or an Ollama model name when Ollama is up
GATEWAY_PREMIUM_BACKEND=openai    # openai | claude
GATEWAY_PREMIUM_MODEL=gpt-5.5

# Force all requests to a single tier (cheap | balanced | premium)
# GATEWAY_FORCE_TIER=

# ── vLLM ─────────────────────────────────────────────────────────────────────
VLLM_BASE_URL=http://vllm:8080/v1
# VLLM_QUANTIZATION=             # e.g. awq, gptq, squeezellm
# VLLM_DTYPE=auto                # or float16, bfloat16

# ── Telemetry ────────────────────────────────────────────────────────────────
# GATEWAY_LEDGER_DB=gateway.db   # path to SQLite file; omit to disable

# ── Modal quantization benchmark ─────────────────────────────────────────────
# QUANT_AWQ_MODEL=               # override default AWQ checkpoint on HF
# MODEL_REVISION=main            # pin to exact HuggingFace commit SHA for reproducibility

# ── Load test ────────────────────────────────────────────────────────────────
# GATEWAY_BASE_URL=http://localhost:8010   # gateway URL for llm-load-test

# ── Custom per-model pricing (USD per token) ─────────────────────────────────
# GATEWAY_PRICE_IN_GPT_4O=0.0000025
# GATEWAY_PRICE_OUT_GPT_4O=0.000010
